{
  "_comment": "Hook registration merged into ~/.claude/settings.json by install-global.sh. Idempotent: re-running replaces these managed hook groups (dedupe by command). Commands use ~ which Claude Code expands to the home dir (Linux and Git-Bash-on-Windows).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/discovery-gate" },
          { "type": "command", "command": "~/.claude/hooks/block-dangerous-git.sh" }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/mcp-soft-discipline" }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/discovery-augment", "timeout": 5 }
        ]
      }
    ],
    "SessionStart": [
      { "matcher": "startup", "hooks": [ { "type": "command", "command": "~/.claude/hooks/discovery-session-reminder" } ] },
      { "matcher": "resume",  "hooks": [ { "type": "command", "command": "~/.claude/hooks/discovery-session-reminder" } ] },
      { "matcher": "clear",   "hooks": [ { "type": "command", "command": "~/.claude/hooks/discovery-session-reminder" } ] },
      { "matcher": "compact", "hooks": [ { "type": "command", "command": "~/.claude/hooks/discovery-session-reminder" } ] }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/filter-test-output" }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/mcp-usage-tracker" }
        ]
      }
    ]
  }
}
